---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const title = 'Labproof — projects you can run, notes from the field';
const description = 'Live and demo projects you can open and run, and direct notes on building intelligence services, automation, and doing business in Malaysia.';

// Pillar id → display label
const pillarLabels = {
  'intelligence-service-building': 'Intelligence Service Building',
  'automation-professional-services': 'Automation in Professional Services',
  'malaysian-market-insights': 'Malaysian Market Insights',
  'products-for-intermediaries': 'Building Products for Intermediaries',
};

// Latest 3 notes, newest first — pulled automatically on every build
const latestNotes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmtDate = (d) =>
  d.toLocaleDateString('en-MY', { year: 'numeric', month: 'short', day: 'numeric' });

// Add new projects here — newest first. type: 'live' | 'demo'.
const projects = [
  {
    title: 'BLUEOS',
    blurb: 'The operating system for vehicle care — car-wash bookings from a WhatsApp link, an availability engine that never double-books, and credit-package memberships.',
    tag: 'Bookings · Vehicle care',
    type: 'live',
    href: '/blueos',
    image: '/img/blueos-card.svg',
    alt: 'BLUEOS — car wash booking and membership platform',
  },
  {
    title: 'THE EXCHANGE',
    blurb: 'Free stock portfolio tracker — live prices, P&L and dividends, all derived from your own trades. One platform, one instance per market: Hong Kong (HKSE) and Malaysia (KLSE) live now.',
    tag: 'Investing · HKSE · KLSE',
    type: 'live',
    href: '/stocktracker',
    image: '/img/stocktracker-card.svg',
    alt: 'THE EXCHANGE — stock portfolio tracker platform',
  },
  {
    title: 'KOVR',
    blurb: "Family. Covered. — keep your family's insurance and emergency numbers in one place.",
    tag: 'Insurance · Family',
    type: 'live',
    href: '/kovr',
    logo: '/img/kovr-icon.svg',
    alt: 'KOVR — family insurance and emergency info',
  },
];
---

<Layout title={title} description={description}>
  <Header />

  <!-- Hero: Notes-forward, equal billing with projects -->
  <section class="pt-[120px] pb-12 md:pt-[150px] md:pb-16 px-6 md:px-20">
    <div class="max-w-container mx-auto">
      <!-- Kicker -->
      <div class="flex items-center gap-2 mb-5 text-mono text-green">
        <span class="inline-block w-2 h-2 rounded-full bg-green"></span>
        <span>Live · Labproof.tech</span>
      </div>

      <!-- Headline + intro -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-end mb-12 md:mb-16">
        <div class="md:col-span-7">
          <h1 class="font-newsreader text-4xl md:text-6xl font-medium tracking-tight leading-[1.05] mb-5">
            Things that work.<br />Notes on why.
          </h1>
          <p class="text-lg md:text-xl text-slate max-w-xl leading-relaxed">
            Two things live here: projects you can open and run, and direct notes from the field on building them. No mockups. No claims.
          </p>
        </div>
        <div class="md:col-span-5 flex flex-col sm:flex-row md:justify-end gap-3">
          <a
            href="/notes"
            class="inline-flex items-center justify-center gap-2 bg-ink text-paper px-6 py-3 rounded-button font-medium hover:shadow-lg hover:-translate-y-1 transition-all duration-150"
          >
            Read the notes
            <svg width="0.9em" height="0.9em" viewBox="0 0 24 24" fill="none">
              <polygon points="0,0 24,12 0,24" fill="#2F9E6A" />
            </svg>
          </a>
          <a
            href="#projects"
            class="inline-flex items-center justify-center gap-2 border-2 border-slate text-ink px-6 py-3 rounded-button font-medium hover:border-ink hover:-translate-y-1 transition-all duration-150"
          >
            See projects
            <svg width="0.9em" height="0.9em" viewBox="0 0 24 24" fill="none">
              <polygon points="0,0 24,12 0,24" fill="#1F7A52" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Latest notes — the hero centerpiece -->
      <div class="flex items-baseline justify-between gap-4 mb-6 pb-4 border-b border-line">
        <h2 class="text-mono text-slate">Latest notes</h2>
        <a href="/notes" class="text-mono text-green hover:text-ink transition-colors">All notes →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {latestNotes.map((note) => (
          <a
            href={`/notes/${note.slug}`}
            class="group flex flex-col p-6 bg-card rounded-card border border-line hover:shadow-card-hover hover:-translate-y-1 transition-all duration-150"
          >
            <div class="flex items-center justify-between gap-3 mb-3">
              <span class="text-mono text-green text-xs">
                {pillarLabels[note.data.pillar]}
              </span>
              <span class="text-mono text-slate text-xs whitespace-nowrap">
                {fmtDate(note.data.date)}
              </span>
            </div>
            <h3 class="font-newsreader text-xl md:text-2xl font-medium text-ink mb-2 leading-snug group-hover:text-green transition-colors">
              {note.data.title}
            </h3>
            <p class="text-slate text-sm leading-relaxed mb-4 flex-1">
              {note.data.excerpt}
            </p>
            <div class="flex items-center justify-between">
              {note.data.readTime && (
                <span class="text-mono text-slate text-xs">{note.data.readTime} min read</span>
              )}
              <span class="text-mono text-slate text-xs opacity-0 group-hover:opacity-100 transition-opacity">Read →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro Strip -->
  <section class="border-t border-b border-line py-8 px-6 md:px-20 bg-white">
    <div class="max-w-container mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <h2 class="font-newsreader text-2xl md:text-3xl font-medium tracking-tight">
          Labproof. Live and running. If it's here, you can press play.
        </h2>
        <p class="text-slate leading-relaxed">
          Every project works. Open it, read the code, run it yourself. Some are finished products. Some are experiments. None are mockups.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 md:py-28 px-6 md:px-20">
    <div class="max-w-container mx-auto">
      <!-- Section Header -->
      <div class="flex items-baseline justify-between gap-4 mb-12">
        <h2 class="font-newsreader text-3xl md:text-4xl font-medium tracking-tight">
          Projects
        </h2>
        <div class="hidden sm:flex gap-2">
          <button class="px-4 py-2 rounded-pill bg-ink text-paper text-mono text-xs font-medium transition-all duration-150 cursor-pointer" data-filter="all">
            All
          </button>
          <button class="px-4 py-2 rounded-pill border-2 border-slate text-slate text-mono text-xs font-medium hover:border-ink hover:text-ink transition-all duration-150 cursor-pointer" data-filter="live">
            Live
          </button>
          <button class="px-4 py-2 rounded-pill border-2 border-slate text-slate text-mono text-xs font-medium hover:border-ink hover:text-ink transition-all duration-150 cursor-pointer" data-filter="demo">
            Demo
          </button>
        </div>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
        {projects.map((project) => (
          <a
            href={project.href}
            data-type={project.type}
            class="project-card group block bg-card rounded-card border border-line overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-150"
          >
            <div class="relative aspect-[16/10] overflow-hidden bg-paper-2 flex items-center justify-center">
              {project.logo ? (
                <div class="flex items-center gap-3">
                  <img
                    src={project.logo}
                    alt=""
                    class="h-14 w-14"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="font-sans text-4xl font-bold tracking-tight text-[#0D1B4B]">{project.title}</span>
                </div>
              ) : (
                <img
                  src={project.image}
                  alt={project.alt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-paper/90 backdrop-blur px-2.5 py-1 rounded-full font-mono text-[10px] font-medium tracking-widest uppercase">
                <span class="w-1.5 h-1.5 rounded-full bg-green"></span>
                {project.type === 'live' ? 'Live' : 'Demo'}
              </span>
              <span class="absolute bottom-3 right-3 inline-flex items-center gap-1 bg-ink text-paper px-3 py-1.5 rounded-full font-mono text-[10px] font-medium tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                Run
                <svg width="0.7em" height="0.7em" viewBox="0 0 24 24" fill="none">
                  <polygon points="0,0 24,12 0,24" fill="#2F9E6A" />
                </svg>
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-newsreader text-xl font-medium mb-1 group-hover:text-green transition-colors">
                {project.title}
              </h3>
              <p class="text-slate text-sm leading-relaxed mb-3">
                {project.blurb}
              </p>
              <p class="font-mono text-[10px] font-medium tracking-widest uppercase text-slate">
                {project.tag}
              </p>
            </div>
          </a>
        ))}
      </div>

      <!-- Filtered-empty state -->
      <div class="hidden text-center py-20" id="projects-empty">
        <p class="text-lg text-slate">No projects in this category yet.</p>
      </div>
    </div>
  </section>

  <script>
    const pButtons = document.querySelectorAll('#projects [data-filter]');
    const pCards = document.querySelectorAll('.project-card');
    const pEmpty = document.getElementById('projects-empty');

    pButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        pButtons.forEach((b) => {
          b.classList.remove('bg-ink', 'text-paper');
          b.classList.add('border-2', 'border-slate', 'text-slate');
        });
        btn.classList.add('bg-ink', 'text-paper');
        btn.classList.remove('border-2', 'border-slate', 'text-slate');

        let visible = 0;
        pCards.forEach((card) => {
          const show = filter === 'all' || card.getAttribute('data-type') === filter;
          card.classList.toggle('hidden', !show);
          if (show) visible++;
        });
        pEmpty?.classList.toggle('hidden', visible !== 0);
      });
    });
  </script>

  <!-- What I write about — pillars + all notes -->
  <section class="py-20 md:py-28 px-6 md:px-20 bg-paper-2">
    <div class="max-w-container mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-newsreader text-3xl md:text-4xl font-medium tracking-tight mb-4">
            What I write about
          </h2>
          <p class="text-lg text-slate mb-8 leading-relaxed">
            Direct thoughts from the field — building intelligence services, wiring automation into professional services, and operating in Malaysia.
          </p>
          <a
            href="/notes"
            class="inline-flex items-center gap-2 px-6 py-3 bg-ink text-paper rounded-[8px] font-medium hover:shadow-lg hover:-translate-y-1 transition-all duration-150"
          >
            Read all notes
            <svg width="0.9em" height="0.9em" viewBox="0 0 24 24" fill="none">
              <polygon points="0,0 24,12 0,24" fill="#2F9E6A" />
            </svg>
          </a>
        </div>
        <div class="block text-slate text-sm space-y-3">
          <p><strong>Intelligence Service Building</strong> — Frameworks, lessons, what works.</p>
          <p><strong>Automation in Professional Services</strong> — Building invisible automation.</p>
          <p><strong>Malaysian Market Insights</strong> — Credit, brand risk, operating realities.</p>
          <p><strong>Building Products for Intermediaries</strong> — Design for accountants, lawyers, cosecs.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .text-mono {
    @apply font-mono text-xs font-medium tracking-widest uppercase;
  }

  .rounded-button {
    @apply transition-all duration-150;
  }

  .rounded-pill {
    @apply rounded-full;
  }

  .rounded-card {
    @apply rounded-[12px];
  }

  .border-line {
    @apply border-[color:var(--line)];
  }

  .shadow-card-hover {
    box-shadow: 0 16px 38px rgba(26, 34, 29, 0.15);
  }
</style>
